# Copy to .env for local dev. .env is gitignored; only .env.example is committed.

# Local dev Postgres (matches docker-compose.yml). The Testcontainers tests ignore this.
DATABASE_URL=postgres://perminou:perminou@localhost:5432/perminou

# Scraper — your OWN NARSA credentials for the authenticated crawl. NEVER commit real values.
# Used by apps/scraper's Playwright login (ADR 0002). Leave blank here.
NARSA_USERNAME=
NARSA_PASSWORD=
